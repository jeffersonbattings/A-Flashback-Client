	if t==moveTouch then local d=t.Position-touchStartPos;moveVector=Vector3.new(d.X/50,0,-d.Y/50)
	elseif t==lookTouch then local d=t.Position-(lookTouch.Position or t.Position);rotY=rotY-d.X*lookSens;rotX=math.clamp(rotX-d.Y*lookSens,-1.5,1.5)end
