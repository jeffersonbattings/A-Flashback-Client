		if v:IsA("Animator")or v:IsA("AnimationController")then pcall(function()v:Destroy()end)end
	end
	for _,v in ipairs(clone:GetDescendants())do
		if v:IsA("BasePart")then v.CanCollide=false;v.Anchored=true end
