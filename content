	local hum=clone:FindFirstChildOfClass("Humanoid")
	if hum then hum.DisplayDistanceType=Enum.HumanoidDisplayDistanceType.None end
	local herp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
	clone:PivotTo(herp and herp.CFrame or cam.CFrame)
	clone.Parent=workspace
	
	for name,part in pairs(partMap)do origPartCF[name]=part.CFrame end
	
	for _,v in ipairs(clone:GetDescendants())do
		if v:IsA("Motor6D")then v.Part0=nil;v.Part1=nil end
	end
	local id=#poseClones+1
	poseClones[id]={Model=clone,Joints=joints,OrigC0=origC0,OrigC1=origC1,Parts=partMap,OrigPartCF=origPartCF,Angles={},History={}}
	return id
end
