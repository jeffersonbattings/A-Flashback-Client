RunService:BindToRenderStep("FBC",Enum.RenderPriority.Camera.Value+1,function(dt)
	if not FreecamEnabled then return end
	local gp=getGP();local md=UIS:GetMouseDelta()
	local function keys(a,b)return(UIS:IsKeyDown(a)and 1 or 0)-(UIS:IsKeyDown(b)and 1 or 0)end
	if camMode=="FirstPerson"then
		local head=getGhostHead()
		if head then cam.CFrame=head.CFrame*CFrame.new(0,0,-0.5)
		elseif lp.Character then local h=lp.Character:FindFirstChild("Head");if h then cam.CFrame=h.CFrame*CFrame.new(0,0,-0.5)end end
	elseif camMode=="Drone"then
		rotY=rotY-md.X*lookSens;rotX=math.clamp(rotX-md.Y*lookSens,-1.5,1.5)
		local rot=CFrame.Angles(0,rotY,0)*CFrame.Angles(rotX,0,0)
		local inp=rot.LookVector*(keys(Enum.KeyCode.W,Enum.KeyCode.S)+moveVector.Z)+rot.RightVector*(keys(Enum.KeyCode.D,Enum.KeyCode.A)+moveVector.X)+Vector3.new(0,keys(Enum.KeyCode.E,Enum.KeyCode.Q),0)
		local thrust=inp.Magnitude>0 and inp.Unit*camSpeed or Vector3.zero
		droneVel=droneVel*0.88+thrust*0.12*60*dt
		if droneVel.Magnitude<0.001 then droneVel=Vector3.zero end
		cam.CFrame=CFrame.new(cam.CFrame.Position+droneVel*dt)*rot
	elseif camMode=="Free"then
		rotY=rotY-md.X*lookSens;rotX=math.clamp(rotX-md.Y*lookSens,-1.5,1.5)
		local rot=CFrame.Angles(0,rotY,0)*CFrame.Angles(rotX,0,0)
		local mv=rot.LookVector*(keys(Enum.KeyCode.W,Enum.KeyCode.S)+moveVector.Z)+rot.RightVector*(keys(Enum.KeyCode.D,Enum.KeyCode.A)+moveVector.X)+Vector3.new(0,keys(Enum.KeyCode.E,Enum.KeyCode.Q),0)
		local tcf=CFrame.new(cam.CFrame.Position+(mv.Magnitude>0 and mv.Unit*camSpeed or Vector3.zero))*rot
		if cinematicCamera then smoothCamCF=(smoothCamCF or tcf):Lerp(tcf,math.clamp(dt*8,0,1));cam.CFrame=smoothCamCF else cam.CFrame=tcf end
	elseif camMode=="Lock"and gp then
		rotY=rotY-md.X*lookSens;rotX=math.clamp(rotX-md.Y*lookSens,-1.5,1.5)
		local rot=CFrame.Angles(0,rotY,0)*CFrame.Angles(rotX,0,0)
		local mv=rot.LookVector*(keys(Enum.KeyCode.W,Enum.KeyCode.S)+moveVector.Z)+rot.RightVector*(keys(Enum.KeyCode.D,Enum.KeyCode.A)+moveVector.X)+Vector3.new(0,keys(Enum.KeyCode.E,Enum.KeyCode.Q),0)
		local tcf=CFrame.new(gp.Position+(cam.CFrame.Position-gp.Position)+(mv.Magnitude>0 and mv.Unit*camSpeed or Vector3.zero),gp.Position)
		if cinematicCamera then smoothCamCF=(smoothCamCF or tcf):Lerp(tcf,math.clamp(dt*6,0,1));cam.CFrame=smoothCamCF else cam.CFrame=tcf end
	elseif camMode=="Orbit"and gp then
		orbitAngle=orbitAngle+md.X*lookSens;orbitHeight=orbitHeight-md.Y*0.1
		orbitDistance=math.clamp(orbitDistance-keys(Enum.KeyCode.W,Enum.KeyCode.S)*camSpeed*0.5,2,50)
		local tcf=CFrame.new(Vector3.new(gp.Position.X+math.cos(orbitAngle)*orbitDistance,gp.Position.Y+orbitHeight,gp.Position.Z+math.sin(orbitAngle)*orbitDistance),gp.Position)
		if cinematicCamera then smoothCamCF=(smoothCamCF or tcf):Lerp(tcf,math.clamp(dt*6,0,1));cam.CFrame=smoothCamCF else cam.CFrame=tcf end
	end
end)

