				if p2.Character then
					local joints={}
					for _,v in ipairs(p2.Character:GetDescendants())do
						if v:IsA("Motor6D")and v.Part0 and v.Part1 then joints[v.Name]=v.C0*v.Transform*v.C1:Inverse()end
					end
					local tool=p2.Character:FindFirstChildOfClass("Tool")
					frame[tostring(p2.UserId)]={Pivot=p2.Character:GetPivot(),Joints=joints,Tool=tool and tool.Name or nil}
				end
