			if recordWorld then
				local charParts=getCharParts()
				local wf={moved={},spawned={},deleted={}}
				local curWS={}
				for _,v in ipairs(workspace:GetDescendants())do
					if v:IsA("BasePart")and not charParts[v]and v~=weatherPart then
						local key=v:GetFullName()
						curWS[key]=v.CFrame
						local last=lastWS[key]
						if not last then
							wf.spawned[key]={cf=v.CFrame,size=v.Size,color=v.Color,material=v.Material,transparency=v.Transparency,anchored=v.Anchored}
						elseif(last.Position-v.CFrame.Position).Magnitude>0.001 then
							wf.moved[key]=v.CFrame
						end
					end
				end
				for key in pairs(lastWS)do if not curWS[key]then wf.deleted[key]=true end end
				lastWS=curWS;frame._world=wf
			end
			replayData[fc]=frame;updateFL();task.wait(1/60)
		end
	end)
