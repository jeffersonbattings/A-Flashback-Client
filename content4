local function playReplay()
	if #replayData==0 then warn("No replay data.")return end
	cleanupGhosts();task.wait(0.1)
	playbackIndex=1;isPlaying=true;activeClones={}
	local ff=replayData[1];if not ff then isPlaying=false;return end
	spawnGhosts(ff)
	task.spawn(function()
		local wFolder=nil
		while isPlaying do
			playbackIndex=math.clamp(playbackIndex+playbackSpeed,1,#replayData)
			local fd=replayData[math.floor(playbackIndex)]
			if fd then
				local wf=fd._world
				if wf then
					if not wFolder then wFolder=workspace:FindFirstChild("Flashback_World");if not wFolder then wFolder=Instance.new("Folder",workspace);wFolder.Name="Flashback_World" end end
					for key,data in pairs(wf.spawned)do
						local nm=key:gsub("[%./]","_")
						if not wFolder:FindFirstChild(nm)then
							local pt=Instance.new("Part",wFolder);pt.Name=nm;pt.CFrame=data.cf;pt.Size=data.size;pt.Color=data.color;pt.Material=data.material;pt.Transparency=data.transparency;pt.Anchored=true;pt.CanCollide=false
						end
					end
					for key,cf in pairs(wf.moved)do local nm=key:gsub("[%./]","_");local pt=wFolder:FindFirstChild(nm);if pt then pt.CFrame=cf end end
					for key in pairs(wf.deleted)do local nm=key:gsub("[%./]","_");local pt=wFolder:FindFirstChild(nm);if pt then pt:Destroy()end end
				end
				for id,g in pairs(activeClones)do
					local pf=fd[id]
					if pf and g.Model then
						g.Model:PivotTo(pf.Pivot)
						for jn2,t in pairs(pf.Joints)do local j=g.Joints[jn2];if j then j.C0=t*j.C1 end end
						if g.Tools then
							for tname,tool in pairs(g.Tools)do
								local show=(pf.Tool==tname)
								for _,p in ipairs(tool:GetDescendants())do if p:IsA("BasePart")then p.LocalTransparencyModifier=show and 0 or 1 end end
							end
						end
					end
				end
			end
			motionBlur.Size=motionBlurEnabled and math.abs(playbackSpeed-1)*8 or 0
			updateFL()
			local atEnd=playbackIndex>=#replayData and playbackSpeed>0
			local atStart=playbackIndex<=1 and playbackSpeed<0
			if atEnd or atStart then
				if loopPlayback then playbackIndex=playbackSpeed>0 and 1 or #replayData else break end
			end
			task.wait(1/60)
		end
		if not loopPlayback then cleanupGhosts()end
	end)
end
