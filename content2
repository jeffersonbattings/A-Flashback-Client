local minimapGui,minimapVP,minimapCam,minimapWM
local minimapLoaded=false
local function loadMinimap()
	if minimapLoaded then return end
	minimapLoaded=true
	minimapWM=Instance.new("WorldModel",minimapVP)
	local center=Vector3.new(0,0,0)
	if lp.Character then local h=lp.Character:FindFirstChild("HumanoidRootPart");if h then center=h.Position end end
	local charParts={}
	for _,p2 in ipairs(game:GetService("Players"):GetPlayers())do
		if p2.Character then for _,v in ipairs(p2.Character:GetDescendants())do if v:IsA("BasePart")then charParts[v]=true end end end
	end
	local count=0
	for _,v in ipairs(workspace:GetDescendants())do
		if v:IsA("BasePart")and not charParts[v]and v.Name~="FlashbackWeather"then
			if(v.Position-center).Magnitude<=150 then
				local ok,clone=pcall(function()v.Archivable=true;return v:Clone()end)
				if ok and clone then
					clone.Anchored=true;clone.CanCollide=false
					for _,s in ipairs(clone:GetDescendants())do if s:IsA("Script")or s:IsA("LocalScript")or s:IsA("ParticleEmitter")then s:Destroy()end end
					clone.Parent=minimapWM;count+=1
					if count>=400 then break end
				end
			end
		end
	end
end

