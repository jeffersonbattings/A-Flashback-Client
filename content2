local function applyTheme(name)
	local t=themes[name];if not t then return end
	frame.BackgroundColor3=t.bg;titleBar.BackgroundColor3=t.title
	for _,v in ipairs(frame:GetDescendants())do
		if v:IsA("TextButton")and v~=minimizeBtn and v~=closeBtn then v.BackgroundColor3=t.btn;v.TextColor3=t.text
		elseif v:IsA("TextBox")then v.BackgroundColor3=C3(math.max(0,t.btn.R*255-10),math.max(0,t.btn.G*255-10),math.max(0,t.btn.B*255-10));v.TextColor3=t.text
		elseif v:IsA("TextLabel")then
			if v.Font==Enum.Font.GothamBold and v.TextSize==8 then v.TextColor3=t.lbl
			elseif v.TextColor3~=C3(255,220,80)then v.TextColor3=t.stat end
		elseif v:IsA("Frame")and v.Size.Y.Offset==1 then v.BackgroundColor3=t.sep end
	end
	if FB.scrubberGui then
		for _,v in ipairs(FB.scrubberGui:GetDescendants())do
			if v:IsA("TextLabel")then v.TextColor3=t.stat
			elseif v:IsA("TextButton")then v.BackgroundColor3=t.scrubHandle end
		end
		scrubFill.BackgroundColor3=t.scrubFill;scrubHandle.BackgroundColor3=t.scrubHandle
		local bg=FB.scrubberGui:FindFirstChildWhichIsA("Frame",true)
		if bg then bg.BackgroundColor3=t.scrubBg end
	end
